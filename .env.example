# Admin dashboard password (change in production!)
ADMIN_KEY=alynaf-admin

# Supabase — server-side only (never expose to client)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
# Recommended for production: Supabase Dashboard → Project Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=

# AI order detection (Claude Haiku) — get from console.anthropic.com
ANTHROPIC_API_KEY=

# Facebook Messenger integration (optional — UI works without these via mock data)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_APP_SECRET=
# Must match the verify token you enter in Facebook App → Messenger → Webhooks
FB_VERIFY_TOKEN=alynaf-webhook

# WhatsApp Business API (optional — UI works without these via mock data)
# Get from Meta for Developers → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
# Must match the verify token you enter in Meta App → WhatsApp → Configuration
WA_VERIFY_TOKEN=alynaf-wa-webhook
